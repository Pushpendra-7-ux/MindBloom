# ============================================
# MindBloom Backend — Environment Variables
# ============================================
# Copy this file to .env and fill in real values.

PORT=5001

# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/mindbloom?retryWrites=true&w=majority

# JWT secret — use a strong random string in production
JWT_SECRET=your_jwt_secret_here

# Gemini API Key — get one from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Twilio (optional — for future SMS/call features)
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_token
TWILIO_PHONE_NUMBER=your_twilio_phone
